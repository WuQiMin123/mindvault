# MindVault 后端环境变量
# 复制此文件为 .env 并填入实际值

# LLM API 配置（必填）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 数据库（可选，默认 SQLite）
# DATABASE_URL=sqlite+aiosqlite:///./data/mindvault.db

# CORS 来源（可选，默认 http://localhost:3000）
# CORS_ORIGINS=["http://localhost:3000"]
